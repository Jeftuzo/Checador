@page "/"
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@inject IJSRuntime JS
@using Checador.Web.Client.Dtos
@using Microsoft.AspNetCore.Components.Forms

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6 card p-4 shadow-sm">
            <h3 class="mb-4 text-primary"><i class="bi bi-clock-history"></i> Reloj Checador de Asistencia</h3>

            <div class="video-container mb-4" style="background-color: #000; border-radius: 8px; overflow: hidden; height: 300px;">
                <video id="videoFeed" width="100%" height="300" autoplay muted playsinline></video>
                <canvas id="canvasOculto" width="400" height="300" style="display:none;"></canvas>
            </div>

            <EditForm Model="@registro" OnValidSubmit="ProcesarRegistro">
                <DataAnnotationsValidator />

                <div class="form-group mb-3 text-start">
                    <label for="numeroEmpleado" class="form-label fw-bold">Número de Empleado</label>
                    <input type="text" id="numeroEmpleado" class="form-control form-control-lg text-center fw-bold"
                           placeholder="Ingresa tu ID" @bind-value="registro.NumeroEmpleado" autofocus />
                    <ValidationMessage For="@(() => registro.NumeroEmpleado)" class="text-danger small" />
                </div>

                <button type="submit" class="btn btn-success btn-lg w-100 py-3 fw-bold fs-5" disabled="@procesando">
                    @if (procesando)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span> Procesando...</span>
                    }
                    else
                    {
                        <span><i class="bi bi-camera-fill"></i> Registrar Entrada / Salida</span>
                    }
                </button>
            </EditForm>

            @if (!string.IsNullOrEmpty(mensajeResultado))
            {
                <div class="alert @(esExito ? "alert-success" : "alert-danger") mt-4 fw-bold" role="alert">
                    @mensajeResultado
                </div>
            }
        </div>
    </div>
</div>

<script>
    window.iniciarCamara = function (idVideo) {
        const video = document.getElementById(idVideo);
        if (!video) return;

        navigator.mediaDevices.getUserMedia({ video: { width: 400, height: 300 }, audio: false })
            .then(stream => {
                video.srcObject = stream;
            })
            .catch(err => {
                console.error("Error al acceder a la cámara web: ", err);
                alert("No se pudo activar la cámara web. Revisa los permisos.");
            });
    };

    window.capturaAutomatica = function (idVideo, idCanvas) {
        const video = document.getElementById(idVideo);
        const canvas = document.getElementById(idCanvas);
        if (!video || !canvas) return "";

        const contexto = canvas.getContext('2d');
        contexto.drawImage(video, 0, 0, 400, 300);
        return canvas.toDataURL('image/jpeg', 0.8);
    };
</script>

@code {
    private RegistroDto registro = new RegistroDto();
    private string mensajeResultado = "";
    private bool esExito = false;
    private bool procesando = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(200);
            await JS.InvokeVoidAsync("iniciarCamara", "videoFeed");
        }
    }

    private async Task ProcesarRegistro()
    {
        procesando = true;
        mensajeResultado = "";

        try
        {
            string fotoBase64 = await JS.InvokeAsync<string>("capturaAutomatica", "videoFeed", "canvasOculto");

            if (string.IsNullOrEmpty(fotoBase64) || fotoBase64.Contains("data:,"))
            {
                esExito = false;
                mensajeResultado = "Error: La cámara no pudo capturar la imagen.";
                procesando = false;
                return;
            }

            registro.Foto = fotoBase64;

            using var client = new HttpClient();

            var respuesta = await client.PostAsJsonAsync("https://localhost:7246/api/Asistencia/registrar", registro);

            if (respuesta.IsSuccessStatusCode)
            {
                var resultadoOk = await respuesta.Content.ReadFromJsonAsync<RespuestaApi>();
                esExito = true;
                mensajeResultado = resultadoOk?.Mensaje ?? "Operación exitosa.";
                registro.NumeroEmpleado = "";
            }
            else
            {
                var resultadoError = await respuesta.Content.ReadFromJsonAsync<RespuestaApi>();
                esExito = false;
                mensajeResultado = resultadoError?.Mensaje ?? "Ocurrió un error en el servidor.";
            }
        }
        catch (Exception ex)
        {
            esExito = false;
            mensajeResultado = $"Error de conexión: {ex.Message}";
        }
        finally
        {
            procesando = false;
        }
    }

    public class RespuestaApi
    {
        public string Mensaje { get; set; } = "";
    }
}