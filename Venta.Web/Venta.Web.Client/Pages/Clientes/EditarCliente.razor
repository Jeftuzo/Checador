@page "/clientes/editar/{Id:int}"
@using Venta.Web.Client.Dtos
@using Venta.Web.Client.Dtos.Clientes
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Editar Cliente</PageTitle>

<div class="container mt-4">
    <div class="card border-warning">
        <div class="card-header bg-warning text-dark">
            <h3>Editar Cliente #@Id</h3>
        </div>
        <div class="card-body">
            @if (cliente == null)
            {
                <p>Cargando datos...</p>
            }
            else
            {
                <EditForm Model="@cliente" OnValidSubmit="Actualizar">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <InputText @bind-Value="cliente.Nombre" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <InputText @bind-Value="cliente.Email" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Teléfono</label>
                        <InputText @bind-Value="cliente.Telefono" class="form-control" />
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-warning">Actualizar Cambios</button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private ClienteActualizarDto? cliente;

    protected override async Task OnInitializedAsync()
    {
        var dtoExistente = await Http.GetFromJsonAsync<ClienteDto>($"api/clientes/{Id}");

        if (dtoExistente != null)
        {
            cliente = new ClienteActualizarDto
            {
                Nombre = dtoExistente.Nombre,
                Email = dtoExistente.Email,
                Telefono = dtoExistente.Telefono
            };
        }
    }

    private async Task Actualizar()
    {
        var response = await Http.PutAsJsonAsync($"api/clientes/{Id}", cliente);

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/clientes");
        }
    }

    private void Cancelar() => Navigation.NavigateTo("/clientes");
}