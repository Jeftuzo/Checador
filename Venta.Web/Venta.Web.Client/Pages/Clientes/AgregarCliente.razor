@page "/clientes/nuevo"
@using Venta.Web.Client.Dtos
@using Venta.Web.Client.Dtos.Clientes
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Agregar Cliente</PageTitle>

<div class="container mt-4">
    <div class="card">
        <div class="card-header">
            <h3>Nuevo Cliente</h3>
        </div>
        <div class="card-body">
            <EditForm Model="@nuevoCliente" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Nombre del Cliente</label>
                    <InputText @bind-Value="nuevoCliente.Nombre" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText @bind-Value="nuevoCliente.Email" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Teléfono</label>
                    <InputText @bind-Value="nuevoCliente.Telefono" class="form-control" />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                    <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private ClienteNuevoDto nuevoCliente = new();

    private async Task Guardar()
    {
        var response = await Http.PostAsJsonAsync("api/clientes", nuevoCliente);

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/clientes");
        }
    }

    private void Cancelar() => Navigation.NavigateTo("/clientes");
}