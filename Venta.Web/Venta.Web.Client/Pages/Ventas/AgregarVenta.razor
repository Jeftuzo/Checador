@page "/ventas/nuevo"
@using Venta.Web.Client.Dtos.Ventas
@using Venta.Web.Client.Dtos.Clientes
@using Venta.Web.Client.Dtos.Productos
@using Venta.Web.Client.Dtos.VentasConcepto
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Agregar Venta</PageTitle>

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3><i class="bi bi-cart-plus"></i> Registrar Nueva Venta</h3>
        </div>
        <div class="card-body">

}            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Seleccionar Cliente</label>
                    <select class="form-select" @bind="nuevaVenta.ClienteId">
                        <option value="0">-- Seleccione un cliente --</option>
                        @if (listaClientes != null)
                        {
                            @foreach (var c in listaClientes)
                            {
                                <option value="@c.Id">@c.Nombre</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6 text-end">
                    <h4 class="text-muted">Total: <span class="text-dark">@nuevaVenta.Total.ToString("C")</span></h4>
                </div>
            </div>

            <hr />

}            <div class="card bg-light mb-4">
                <div class="card-body">
                    <h5>Añadir Productos</h5>
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label">Producto</label>
                            <select class="form-select" @onchange="OnProductoSelected">
                                <option value="0">-- Seleccione un producto --</option>
                                @if (listaProductos != null)
                                {
                                    @foreach (var p in listaProductos)
                                    {
                                        <option value="@p.Id">@p.Nombre (@p.Precio.ToString("C"))</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Cantidad</label>
                            <input type="number" class="form-control" @bind="cantidadTemporal" min="1" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="button" class="btn btn-success w-100" @onclick="AgregarAlCarrito">
                                <i class="bi bi-plus-lg"></i> Agregar al Carrito
                            </button>
                        </div>
                    </div>
                </div>
            </div>

}            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Producto</th>
                        <th>Cant.</th>
                        <th>Precio Unit.</th>
                        <th>Subtotal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in nuevaVenta.Conceptos)
                    {
                        var nombreProd = listaProductos?.FirstOrDefault(p => p.Id == item.ProductoId)?.Nombre ?? "Producto";
                        <tr>
                            <td>@nombreProd</td>
                            <td>@item.Cantidad</td>
                            <td>@item.ValorUnitario.ToString("C")</td>
                            <td>@((item.Cantidad * item.ValorUnitario).ToString("C"))</td>
                            <td>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => QuitarDelCarrito(item)">
                                    <i class="bi bi-x-circle"></i>
                                    Eliminar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="mt-4 text-end">
                <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                <button type="button" class="btn btn-primary btn-lg" @onclick="GuardarVenta"
                        disabled="@(nuevaVenta.Conceptos.Count == 0 || nuevaVenta.ClienteId == 0)">
                    Finalizar Venta
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private VentaNuevaDto nuevaVenta = new();
    private ClienteDto[]? listaClientes;
    private ProductoDto[]? listaProductos;

    private int cantidadTemporal = 1;
    private ProductoDto? productoSeleccionado;

    protected override async Task OnInitializedAsync()
    {
        listaClientes = await Http.GetFromJsonAsync<ClienteDto[]>("api/clientes");
        listaProductos = await Http.GetFromJsonAsync<ProductoDto[]>("api/productos");
    }

    private void OnProductoSelected(ChangeEventArgs e)
    {
        int id = int.Parse(e.Value?.ToString() ?? "0");
        productoSeleccionado = listaProductos?.FirstOrDefault(p => p.Id == id);
    }

    private void AgregarAlCarrito()
    {
        if (productoSeleccionado == null || cantidadTemporal < 1) return;

        var nuevoConcepto = new VentaConceptoNuevoDto
        {
            ProductoId = productoSeleccionado.Id,
            Cantidad = cantidadTemporal,
            ValorUnitario = productoSeleccionado.Precio
        };

        nuevaVenta.Conceptos.Add(nuevoConcepto);
        CalcularTotal();

        cantidadTemporal = 1;
    }

    private void QuitarDelCarrito(VentaConceptoNuevoDto item)
    {
        nuevaVenta.Conceptos.Remove(item);
        CalcularTotal();
    }

    private void CalcularTotal()
    {
        nuevaVenta.Total = nuevaVenta.Conceptos.Sum(c => c.Cantidad * c.ValorUnitario);
    }

    private async Task GuardarVenta()
    {
        var response = await Http.PostAsJsonAsync("api/ventas", nuevaVenta);

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/ventas");
        }
    }

    private void Cancelar() => Navigation.NavigateTo("/ventas");
}