@page "/ventas"
@using Venta.Web.Client.Dtos
@using Venta.Web.Client.Dtos.Ventas
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Ventas</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Ventas Realizadas</h1>
    <button class="btn btn-success" @onclick="IrAAgregar">
        <i class="bi bi-plus-circle"></i> Agregar Venta
    </button>
</div>

@if (ventas == null)
{
    <p><em>Cargando historial de ventas...</em></p>
}
else if (ventas.Length == 0)
{
    <p>No se encontraron ventas registradas.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th style="width: 150px">Acciones</th>
                <th>Id</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in ventas)
            {
                <tr>
                    <td>
                        <div class="btn-group" role="group">

                            <button class="btn btn-primary btn-sm" @onclick="() => Editar(item.Id)">
                                <i class="bi bi-pencil"></i>
                                Editar
                            </button>

                            <button class="btn btn-danger btn-sm" @onclick="() => Eliminar(item.Id)">
                                <i class="bi bi-trash"></i>
                                Eliminar
                            </button>

                        </div>
                    </td>
                    <td>@item.Id</td>
                    <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@item.NombreCliente</td>
                    <td>@item.Total.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private VentaDto[]? ventas;

    protected override async Task OnInitializedAsync()
    {
        await CargarVentas();
    }

    private async Task CargarVentas()
    {
        try
        {
            ventas = await Http.GetFromJsonAsync<VentaDto[]>("api/ventas");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar ventas: {ex.Message}");
        }
    }

    private void IrAAgregar()
    {
        Navigation.NavigateTo("/ventas/nuevo");
    }

    private void Editar(int id)
    {
        Navigation.NavigateTo($"/ventas/editar/{id}");
    }
        
    private async Task Eliminar(int id)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", "¿Estás seguro de que deseas eliminar esta venta?");

        if (confirmado)
        {
            try
            {
                var response = await Http.DeleteAsync($"api/ventas/{id}");
                if (response.IsSuccessStatusCode)
                {
                    await CargarVentas();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error al eliminar: {ex.Message}");
            }
        }
    }
}