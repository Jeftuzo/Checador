@page "/ventas/editar/{Id:int}"
@using Venta.Web.Client.Dtos.Ventas
@using Venta.Web.Client.Dtos.VentasConcepto
@using Venta.Web.Client.Dtos.Clientes
@using Venta.Web.Client.Dtos.Productos
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Editar Venta #@Id</PageTitle>

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h3><i class="bi bi-pencil-square"></i> Editar Venta #@Id</h3>
        </div>
        <div class="card-body">
            @if (ventaParaEditar == null)
            {
                <div class="text-center">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p>Cargando datos de la venta...</p>
                </div>
            }
            else
            {
                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Cliente</label>
                        <select class="form-select" @bind="ventaParaEditar.ClienteId">
                            <option value="0">-- Seleccione un cliente --</option>
                            @if (listaClientes != null)
                            {
                                @foreach (var c in listaClientes)
                                {
                                    <option value="@c.Id">@c.Nombre</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6 text-end">
                        <h4 class="text-muted">Total: <span class="text-dark">@ventaParaEditar.Total.ToString("C")</span></h4>
                    </div>
                </div>

                <hr />

                <div class="card bg-light mb-4">
                    <div class="card-body">
                        <h5>Añadir más productos</h5>
                        <div class="row g-3">
                            <div class="col-md-5">
                                <select class="form-select" @onchange="OnProductoSelected">
                                    <option value="0">-- Seleccione producto para agregar --</option>
                                    @if (listaProductos != null)
                                    {
                                        @foreach (var p in listaProductos)
                                        {
                                            <option value="@p.Id">@p.Nombre (@p.Precio.ToString("C"))</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <input type="number" class="form-control" @bind="cantidadTemporal" min="1" />
                            </div>
                            <div class="col-md-4">
                                <button type="button" class="btn btn-success w-100" @onclick="AgregarNuevoConcepto">
                                    <i class="bi bi-plus-lg"></i> Agregar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <table class="table">
                    <thead class="table-dark">
                        <tr>
                            <th>Producto</th>
                            <th>Cant.</th>
                            <th>Precio Unit.</th>
                            <th>Subtotal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ventaParaEditar.Conceptos)
                        {
                            var nombreProd = listaProductos?.FirstOrDefault(p => p.Id == item.ProductoId)?.Nombre ?? "Producto";
                            <tr>
                                <td>@nombreProd</td>
                                <td>
                                    <input type="number" class="form-control form-control-sm"
                                           style="width: 80px" @bind="item.Cantidad" @bind:after="CalcularTotal" />
                                </td>
                                <td>@item.ValorUnitario.ToString("C")</td>
                                <td>@((item.Cantidad * item.ValorUnitario).ToString("C"))</td>
                                <td>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => QuitarConcepto(item)">
                                        <i class="bi bi-trash"></i>
                                        Eliminar
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="mt-4 text-end">
                    <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    <button type="button" class="btn btn-warning" @onclick="GuardarCambios">
                        Actualizar Venta
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private VentaActualizarDto? ventaParaEditar;
    private ClienteDto[]? listaClientes;
    private ProductoDto[]? listaProductos;

    private int cantidadTemporal = 1;
    private ProductoDto? productoSeleccionado;

    protected override async Task OnInitializedAsync()
    {
        listaClientes = await Http.GetFromJsonAsync<ClienteDto[]>("api/clientes");
        listaProductos = await Http.GetFromJsonAsync<ProductoDto[]>("api/productos");

        var ventaDto = await Http.GetFromJsonAsync<VentaDto>($"api/ventas/{Id}");

        if (ventaDto != null)
        {
            ventaParaEditar = new VentaActualizarDto
            {
                ClienteId = 0, 
                Total = ventaDto.Total,
                Conceptos = ventaDto.Conceptos.Select(c => new VentaConceptoActualizarDto
                {
                    Id = c.Id,
                    ProductoId = listaProductos?.FirstOrDefault(p => p.Nombre == c.NombreProducto)?.Id ?? 0,
                    Cantidad = c.Cantidad,
                    ValorUnitario = c.ValorUnitario
                }).ToList()
            };

            ventaParaEditar.ClienteId = listaClientes?.FirstOrDefault(cl => cl.Nombre == ventaDto.NombreCliente)?.Id ?? 0;
        }
    }

    private void OnProductoSelected(ChangeEventArgs e)
    {
        int idProd = int.Parse(e.Value?.ToString() ?? "0");
        productoSeleccionado = listaProductos?.FirstOrDefault(p => p.Id == idProd);
    }

    private void AgregarNuevoConcepto()
    {
        if (productoSeleccionado == null || ventaParaEditar == null) return;

        ventaParaEditar.Conceptos.Add(new VentaConceptoActualizarDto
        {
            Id = 0,
            ProductoId = productoSeleccionado.Id,
            Cantidad = cantidadTemporal,
            ValorUnitario = productoSeleccionado.Precio
        });

        CalcularTotal();
    }

    private void QuitarConcepto(VentaConceptoActualizarDto item)
    {
        ventaParaEditar?.Conceptos.Remove(item);
        CalcularTotal();
    }

    private void CalcularTotal()
    {
        if (ventaParaEditar != null)
            ventaParaEditar.Total = ventaParaEditar.Conceptos.Sum(c => c.Cantidad * c.ValorUnitario);
    }

    private async Task GuardarCambios()
    {
        var response = await Http.PutAsJsonAsync($"api/ventas/{Id}", ventaParaEditar);
        if (response.IsSuccessStatusCode) Navigation.NavigateTo("/ventas");
    }

    private void Cancelar() => Navigation.NavigateTo("/ventas");
}