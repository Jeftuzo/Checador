@page "/productos"
@using Venta.Web.Client.Dtos
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Productos</h1>
    <button class="btn btn-success" @onclick="IrAAgregar">
        <i class="bi bi-plus-circle"></i> Agregar Producto
    </button>
</div>

@if (productos == null)
{
    <p><em>Cargando...</em></p>
}
else if (productos.Length == 0)
{
    <p>No se encontraron productos.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th style="width: 150px">Acciones</th>
                <th>Id</th>
                <th>Nombre</th>
                <th>Precio</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in productos)
            {
                <tr>
                    <td>
                        <div class="btn-group" role="group">
                            <button class="btn btn-primary btn-sm" @onclick="() => Editar(item.Id)">
                                Editar
                            </button>
                            <button class="btn btn-danger btn-sm" @onclick="() => Eliminar(item.Id)">
                                Eliminar
                            </button>
                        </div>
                    </td>
                    <td>@item.Id</td>
                    <td>@item.Nombre</td>
                    <td>@item.Precio.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private ProductoDto[]? productos;

    protected override async Task OnInitializedAsync()
    {
        await CargarProductos();
    }

    private async Task CargarProductos()
    {
        try
        {
            productos = await Http.GetFromJsonAsync<ProductoDto[]>("api/productos");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar productos: {ex.Message}");
        }
    }

    private void IrAAgregar()
    {
        Navigation.NavigateTo("/productos/nuevo");
    }

    private void Editar(int id)
    {
        Navigation.NavigateTo($"/productos/editar/{id}");
    }

    private async Task Eliminar(int id)
    {
        var confirmado = await Task.FromResult(true);

        if (confirmado)
        {
            try
            {
                var response = await Http.DeleteAsync($"api/productos/{id}");
                if (response.IsSuccessStatusCode)
                {
                    await CargarProductos();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error al eliminar: {ex.Message}");
            }
        }
    }
}