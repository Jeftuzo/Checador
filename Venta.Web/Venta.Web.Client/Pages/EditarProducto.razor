@page "/productos/editar/{Id:int}"
@using Venta.Web.Client.Dtos
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="card border-warning">
        <div class="card-header bg-warning text-dark">
            <h3>Editar Producto #@Id</h3>
        </div>
        <div class="card-body">
            @if (producto == null)
            {
                <p>Cargando datos...</p>
            }
            else
            {
                <EditForm Model="@producto" OnValidSubmit="Actualizar">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <InputText @bind-Value="producto.Nombre" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Precio</label>
                        <InputNumber @bind-Value="producto.Precio" class="form-control" />
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-warning">Actualizar Cambios</button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private ProductoActualizarDto? producto;

    protected override async Task OnInitializedAsync()
    {
        var dtoExistente = await Http.GetFromJsonAsync<ProductoDto>($"api/productos/{Id}");

        if (dtoExistente != null)
        {
            producto = new ProductoActualizarDto
            {
                Nombre = dtoExistente.Nombre,
                Precio = dtoExistente.Precio
            };
        }
    }

    private async Task Actualizar()
    {
        var response = await Http.PutAsJsonAsync($"api/productos/{Id}", producto);

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/productos");
        }
    }

    private void Cancelar() => Navigation.NavigateTo("/productos");
}